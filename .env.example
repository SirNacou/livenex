# Bun Configuration
BUN_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/livenex

# Redis Configuration (for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Backend Configuration
PORT=3001
BACKEND_INTERNAL_URL=http://localhost:3001
BACKEND_PUBLIC_URL=https://localhost

# Frontend Configuration
VITE_FRONTEND_URL=https://localhost
VITE_API_URL=https://localhost/api

# Authentication Configuration
BETTER_AUTH_SECRET=your-secret-key-change-in-production

# Session Configuration
SESSION_TIMEOUT_DAYS=30

# Environment
NODE_ENV=development
DEBUG=false

# Bun-specific runtime options (optional)
# BUN_RUNTIME_TRANSPILER_CACHE=true
