# Environment
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/livenex

# Redis Configuration (for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Server Configuration (Unified TanStack Start + ElysiaJS)
PORT=3000
BASE_URL=http://localhost:3000

# Authentication Configuration
AUTH_SECRET=your-secret-key-change-this-in-production

# Session Configuration
SESSION_TIMEOUT_DAYS=30

# Debug
DEBUG=false

# OIDC (optional, for future implementation)
# OIDC_PROVIDER_URL=https://your-oidc-provider.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
