{
  "name": "@livenex/backend",
  "version": "0.1.0",
  "type": "module",
  "description": "Livenex ElysiaJS API backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --hot src/app.ts",
    "build": "bun build ./src/app.ts --outdir dist --minify",
    "preview": "bun dist/app.js",
    "start": "bun start --hot src/app.ts",
    "test": "bun test",
    "db:migrate": "bun drizzle-kit migrate",
    "db:push": "bun drizzle-kit push",
    "db:generate": "bun drizzle-kit generate",
    "db:studio": "bun drizzle-kit studio"
  },
  "dependencies": {
    "elysia": "^1.1.20",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.1",
    "@libsql/client": "^0.5.0",
    "better-auth": "^1.1.13",
    "zod": "^3.23.8",
    "uuid": "^9.0.0",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "bun-types": "^1.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.12.2",
    "@types/uuid": "^9.0.0",
    "drizzle-kit": "^0.23.1"
  }
}
